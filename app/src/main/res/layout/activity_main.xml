<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.tools.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Top Bar cố định -->
    <LinearLayout
        android:id="@+id/ll_top_bar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="16dp"
        android:background="@color/white">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TW"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#D9A441" />
    </LinearLayout>

    <View
        android:id="@+id/v_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_below="@id/ll_top_bar"
        android:background="#EEEEEE"/>

    <!-- NỘI DUNG CHÍNH CỦA ACTIVITY_MAIN (Danh sách truyện) -->
    <ScrollView
        android:id="@+id/home_content_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/v_divider"
        android:layout_above="@+id/bottom_navigation_container"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- Section: Mới đăng -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="16dp"
                android:paddingHorizontal="16dp"
                android:paddingBottom="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mới đăng"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Xem Thêm ▸"
                    android:textSize="13sp"
                    android:textColor="#D9A441"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"/>
            </RelativeLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp">
                    <LinearLayout android:layout_width="100dp" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginEnd="16dp">
                        <com.makeramen.roundedimageview.RoundedImageView android:layout_width="match_parent" android:layout_height="140dp" android:src="@drawable/image5" android:scaleType="centerCrop" app:riv_corner_radius="8dp"/>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Gieo Lại Mầm Sáng Ở Vùng..." android:textSize="13sp" android:textStyle="bold" android:textColor="@color/black" android:maxLines="2" android:ellipsize="end" android:layout_marginTop="8dp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="100dp" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginEnd="16dp">
                        <com.makeramen.roundedimageview.RoundedImageView android:layout_width="match_parent" android:layout_height="140dp" android:src="@drawable/image5" android:scaleType="centerCrop" app:riv_corner_radius="8dp"/>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Sự Đồng Bộ Hoàn Mỹ" android:textSize="13sp" android:textStyle="bold" android:textColor="@color/black" android:maxLines="2" android:ellipsize="end" android:layout_marginTop="8dp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="100dp" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginEnd="16dp">
                        <com.makeramen.roundedimageview.RoundedImageView android:layout_width="match_parent" android:layout_height="140dp" android:src="@drawable/image5" android:scaleType="centerCrop" app:riv_corner_radius="8dp"/>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Sao Rơi" android:textSize="13sp" android:textStyle="bold" android:textColor="@color/black" android:maxLines="2" android:ellipsize="end" android:layout_marginTop="8dp"/>
                    </LinearLayout>
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Section: Mới cập nhật -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="24dp"
                android:paddingHorizontal="16dp"
                android:paddingBottom="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mới cập nhật"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Xem Thêm ▸"
                    android:textSize="13sp"
                    android:textColor="#D9A441"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"/>
            </RelativeLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp">
                    <LinearLayout android:layout_width="100dp" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginEnd="16dp">
                        <com.makeramen.roundedimageview.RoundedImageView android:layout_width="match_parent" android:layout_height="140dp" android:src="@drawable/image5" android:scaleType="centerCrop" app:riv_corner_radius="8dp"/>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="[Mỹ Thực] Quán Ăn Từ Kỷ" android:textSize="13sp" android:textStyle="bold" android:textColor="@color/black" android:maxLines="2" android:ellipsize="end" android:layout_marginTop="8dp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="100dp" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginEnd="16dp">
                        <com.makeramen.roundedimageview.RoundedImageView android:layout_width="match_parent" android:layout_height="140dp" android:src="@drawable/image5" android:scaleType="centerCrop" app:riv_corner_radius="8dp"/>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Sự Đồng Bộ Hoàn Mỹ" android:textSize="13sp" android:textStyle="bold" android:textColor="@color/black" android:maxLines="2" android:ellipsize="end" android:layout_marginTop="8dp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="100dp" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginEnd="16dp">
                        <com.makeramen.roundedimageview.RoundedImageView android:layout_width="match_parent" android:layout_height="140dp" android:src="@drawable/image5" android:scaleType="centerCrop" app:riv_corner_radius="8dp"/>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Bí Mật Thành Phố" android:textSize="13sp" android:textStyle="bold" android:textColor="@color/black" android:maxLines="2" android:ellipsize="end" android:layout_marginTop="8dp"/>
                    </LinearLayout>
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Section: Truyện đã hoàn thành -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="24dp"
                android:paddingHorizontal="16dp"
                android:paddingBottom="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Truyện đã hoàn thành"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Xem Thêm ▸"
                    android:textSize="13sp"
                    android:textColor="#D9A441"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"/>
            </RelativeLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp">
                    <LinearLayout android:layout_width="100dp" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginEnd="16dp">
                        <com.makeramen.roundedimageview.RoundedImageView android:layout_width="match_parent" android:layout_height="140dp" android:src="@drawable/image5" android:scaleType="centerCrop" app:riv_corner_radius="8dp"/>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Truyện Hoàn Thành 1" android:textSize="13sp" android:textStyle="bold" android:textColor="@color/black" android:maxLines="2" android:ellipsize="end" android:layout_marginTop="8dp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="100dp" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginEnd="16dp">
                        <com.makeramen.roundedimageview.RoundedImageView android:layout_width="match_parent" android:layout_height="140dp" android:src="@drawable/image5" android:scaleType="centerCrop" app:riv_corner_radius="8dp"/>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Truyện Hoàn Thành 2" android:textSize="13sp" android:textStyle="bold" android:textColor="@color/black" android:maxLines="2" android:ellipsize="end" android:layout_marginTop="8dp"/>
                    </LinearLayout>
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Section: Truyện đọc gần đây -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="24dp"
                android:paddingHorizontal="16dp"
                android:paddingBottom="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Truyện đọc gần đây"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Xem Thêm ▸"
                    android:textSize="13sp"
                    android:textColor="#D9A441"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"/>
            </RelativeLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp">
                    <LinearLayout android:layout_width="100dp" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginEnd="16dp">
                        <com.makeramen.roundedimageview.RoundedImageView android:layout_width="match_parent" android:layout_height="140dp" android:src="@drawable/image5" android:scaleType="centerCrop" app:riv_corner_radius="8dp"/>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Truyện Gần Đây 1" android:textSize="13sp" android:textStyle="bold" android:textColor="@color/black" android:maxLines="2" android:ellipsize="end" android:layout_marginTop="8dp"/>
                    </LinearLayout>
                </LinearLayout>
            </HorizontalScrollView>

        </LinearLayout>
    </ScrollView>

    <!-- Hộp chứa các Fragment khác (Search, Write, Profile...) -->
    <FrameLayout
        android:id="@+id/main_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/v_divider"
        android:layout_above="@+id/bottom_navigation_container"
        android:visibility="gone" />

    <!-- Thanh điều hướng ở dưới cùng -->
    <FrameLayout
        android:id="@+id/bottom_navigation_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true">
        <include layout="@layout/layout_bottom_navigation" />
    </FrameLayout>

</RelativeLayout>
