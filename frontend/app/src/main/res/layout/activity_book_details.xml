<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginTop="27dp"
    android:background="@color/white">


    <!-- Header / Back Button -->
    <ImageView
        android:id="@+id/btn_back"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_margin="16dp"
        android:src="@android:drawable/ic_menu_revert"
        android:rotation="0"
        app:tint="@color/text_dark" />


    <ScrollView
        android:id="@+id/content_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/btn_back"
        android:layout_above="@+id/bottom_bar"
        android:paddingHorizontal="16dp"
        android:clipToPadding="false">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">


            <!-- Top Section: Image and Basic Info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">


                <com.makeramen.roundedimageview.RoundedImageView
                    android:id="@+id/iv_book_cover"
                    android:layout_width="120dp"
                    android:layout_height="170dp"
                    android:src="@drawable/biatruyen"
                    android:scaleType="centerCrop"
                    app:riv_corner_radius="12dp" />


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">


                    <TextView
                        android:id="@+id/tv_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Gieo Lại Mầm Sáng Ở Vùng Phế Tích"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:lineSpacingExtra="4dp" />


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="12dp">


                        <com.makeramen.roundedimageview.RoundedImageView
                            android:id="@+id/iv_author_avatar"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/avatar"
                            android:scaleType="centerCrop"
                            app:riv_oval="true" />


                        <TextView
                            android:id="@+id/tv_author"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Aneira"
                            android:textColor="@color/text_dark"
                            android:layout_marginStart="8dp"
                            android:textSize="14sp" />
                    </LinearLayout>


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="20dp"
                        android:gravity="center_vertical">
                        <TextView
                            android:id="@+id/tv_views_count"
                            android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="👁 777 N" android:textSize="13sp" android:textColor="@color/text_dark"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="  🔖 11,4 N" android:textSize="13sp" android:textColor="@color/text_dark" android:layout_marginStart="8dp"/>
                        <TextView
                            android:id="@+id/tv_chapters_count"
                            android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="  ≡ 45 chương" android:textSize="13sp" android:textColor="@color/text_dark" android:layout_marginStart="8dp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>


            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" android:layout_marginBottom="12dp"/>


            <!-- Status Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">
                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@android:drawable/ic_menu_agenda"
                    app:tint="@color/black"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dang tiến hành"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:layout_marginStart="8dp"
                    android:textSize="14sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="6 giờ"
                    android:textColor="@color/text_dark"
                    android:layout_marginStart="8dp"
                    android:textSize="14sp"/>
            </LinearLayout>


            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" android:layout_marginBottom="16dp"/>


            <!-- Genre Chips -->
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/cg_genres"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:chipSpacingHorizontal="8dp">
                <com.google.android.material.chip.Chip style="@style/Widget.MaterialComponents.Chip.Action" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ngôn tình" app:chipBackgroundColor="@color/gray_bg" android:textColor="@color/text_dark" android:textSize="12sp"/>
                <com.google.android.material.chip.Chip style="@style/Widget.MaterialComponents.Chip.Action" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lãng mạn" app:chipBackgroundColor="@color/gray_bg" android:textColor="@color/text_dark" android:textSize="12sp"/>
                <com.google.android.material.chip.Chip style="@style/Widget.MaterialComponents.Chip.Action" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Điền văn" app:chipBackgroundColor="@color/gray_bg" android:textColor="@color/text_dark" android:textSize="12sp"/>
                <com.google.android.material.chip.Chip style="@style/Widget.MaterialComponents.Chip.Action" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="HE" app:chipBackgroundColor="@color/gray_bg" android:textColor="@color/text_dark" android:textSize="12sp"/>
            </com.google.android.material.chip.ChipGroup>


            <!-- Rating Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:id="@+id/ll_stars"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@android:drawable/btn_star_big_on" app:tint="#FFC107"/>
                    <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@android:drawable/btn_star_big_on" app:tint="#FFC107"/>
                    <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@android:drawable/btn_star_big_on" app:tint="#FFC107"/>
                    <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@android:drawable/btn_star_big_on" app:tint="#FFC107"/>
                    <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@android:drawable/btn_star_big_off" app:tint="#D3D3D3"/>
                </LinearLayout>
                <TextView
                    android:id="@+id/tv_rating_score"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4.0"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:layout_marginStart="12dp"/>
            </LinearLayout>


            <!-- Follow Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_follow_book"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="THEO DÕI TRUYỆN"
                android:backgroundTint="@color/primary"
                android:textColor="@color/white"
                app:icon="@android:drawable/btn_star_big_off"
                app:iconTint="@color/white"
                android:layout_marginBottom="12dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="8dp" />


            <!-- Comment Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_comments"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bình luận"
                android:textColor="@color/primary"
                app:strokeColor="@color/primary"
                app:icon="@android:drawable/stat_notify_chat"
                app:iconTint="@color/primary"
                android:layout_marginBottom="24dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="20dp" />


            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" android:layout_marginBottom="16dp"/>


            <!-- Detailed Info Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">


                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Tên truyện: Gieo Lại Mầm Sáng Ở Vùng Phế Tích" android:textColor="@color/black" android:layout_marginBottom="4dp"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Tên gốc: Nhà Trẻ Số Một Vũ Trụ" android:textColor="@color/black" android:layout_marginBottom="4dp"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Tác giả: Trường Nhạc Tư Ương" android:textColor="@color/black" android:layout_marginBottom="4dp"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Thể loại: Ngôn tình, Lãng mạng, Điền văn, HE" android:textColor="@color/black" android:layout_marginBottom="4dp"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Nhóm chuyển ngữ: Lavender team" android:textColor="@color/black" android:layout_marginBottom="4dp"/>


                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Văn án:"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="4dp"/>


                <TextView
                    android:id="@+id/tv_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Lời tựa: Chỉ cần dành cho các con thật nhiều yêu thương và che chở, bất kỳ cây non nào cũng có thể lớn lên trở thành vòm đại thụ che cả bầu trời.\n\nKhởi đầu từ một nhà trẻ đổ nát hoang tàn, toàn bộ quá trình thăng cấp đều nhờ vào mấy bé thú có bộ lông mềm mượt!\n\n...!"
                    android:textColor="@color/text_dark"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="24dp"/>
            </LinearLayout>


        </LinearLayout>
    </ScrollView>


    <!-- Bottom Action Bar -->
    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_alignParentBottom="true"
        android:background="@color/white"
        android:elevation="8dp"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:gravity="center_vertical"
        android:paddingBottom="4dp">


        <LinearLayout
            android:id="@+id/btn_collection"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_input_add"
                app:tint="@color/primary"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thêm vào BST"
                android:textSize="10sp"
                android:textColor="@color/primary"/>
        </LinearLayout>


        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_read"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1.5"
            android:text="ĐỌC TRUYỆN"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="@color/primary"
            android:textColor="@color/white"
            app:cornerRadius="25dp"
            android:layout_marginHorizontal="16dp"/>


        <LinearLayout
            android:id="@+id/btn_toc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_sort_by_size"
                app:tint="@color/primary"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mục lục"
                android:textSize="10sp"
                android:textColor="@color/primary"/>
        </LinearLayout>
    </LinearLayout>


</RelativeLayout>
