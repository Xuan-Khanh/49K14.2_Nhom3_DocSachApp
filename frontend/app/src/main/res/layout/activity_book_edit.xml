<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- MÀN HÌNH CHÍNH -->
    <LinearLayout
        android:id="@+id/layout_edit_main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header cố định -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:paddingHorizontal="16dp"
            android:layout_marginTop="27dp">
            <ImageView
                android:id="@+id/btn_close"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_centerVertical="true"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="@color/black" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Sửa thông tin truyện"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold" />
            <ImageView
                android:id="@+id/btn_save"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/tick"
                android:alpha="0.3"
                android:enabled="false" />
        </RelativeLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true"
            android:scrollbars="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp">

                <!-- Phần Bìa truyện -->
                <LinearLayout
                    android:id="@+id/layout_edit_cover"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="20dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">

                    <com.makeramen.roundedimageview.RoundedImageView
                        android:id="@+id/iv_book_cover"
                        android:layout_width="64dp"
                        android:layout_height="88dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/anhtruyen"
                        app:riv_corner_radius="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="20dp"
                        android:text="Chỉnh sửa bìa truyện"
                        android:textColor="@color/black"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

                <!-- Tiêu đề -->
                <RelativeLayout
                    android:id="@+id/layout_edit_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingVertical="20dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">
                    <TextView android:id="@+id/label_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tiêu đề *" android:textColor="@color/black" android:textStyle="bold" android:textSize="15sp"/>
                    <ImageView android:id="@+id/ic_arrow_1" android:layout_width="16dp" android:layout_height="16dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:src="@drawable/ic_chevron_right" app:tint="@color/black" />
                    <TextView android:id="@+id/tv_display_title" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_toEndOf="@id/label_title" android:layout_toStartOf="@id/ic_arrow_1" android:layout_centerVertical="true" android:gravity="end" android:layout_marginEnd="8dp" android:text="..." android:textColor="#555555" android:textSize="15sp" android:singleLine="true" android:ellipsize="end"/>
                </RelativeLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

                <!-- Mô tả -->
                <RelativeLayout
                    android:id="@+id/layout_edit_desc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="20dp"
                    android:paddingBottom="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">
                    <TextView android:id="@+id/label_desc" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mô tả *" android:textColor="@color/black" android:textStyle="bold" android:textSize="15sp"/>
                    <ImageView android:id="@+id/ic_arrow_2" android:layout_width="16dp" android:layout_height="16dp" android:layout_alignParentEnd="true" android:src="@drawable/ic_chevron_right" app:tint="@color/black" />
                    <TextView android:id="@+id/tv_book_desc" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_below="@id/label_desc" android:layout_marginTop="8dp" android:text="..." android:textColor="#666666" android:textSize="14sp" android:ellipsize="end" android:maxLines="3" android:lineSpacingExtra="4dp"/>
                </RelativeLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

                <!-- Thể loại -->
                <RelativeLayout
                    android:id="@+id/layout_edit_category"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingVertical="20dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">
                    <TextView android:id="@+id/label_cat" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Thể loại *" android:textColor="@color/black" android:textStyle="bold" android:textSize="15sp"/>
                    <ImageView android:id="@+id/ic_arrow_3" android:layout_width="16dp" android:layout_height="16dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:src="@drawable/ic_chevron_right" app:tint="@color/black" />
                    <TextView android:id="@+id/tv_book_categories" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_toEndOf="@id/label_cat" android:layout_toStartOf="@id/ic_arrow_3" android:layout_centerVertical="true" android:gravity="end" android:layout_marginEnd="8dp" android:text="Chưa chọn" android:textColor="#555555" android:textSize="15sp" android:singleLine="true" android:ellipsize="end"/>
                </RelativeLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

                <!-- Đã hoàn thành -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingVertical="12dp">
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Đã hoàn thành" android:textColor="@color/black" android:textStyle="bold" android:textSize="15sp"/>
                        <TextView android:id="@+id/tv_status_label" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Đang tiến hành" android:textColor="#888888" android:textSize="12sp" />
                    </LinearLayout>
                    <Switch android:id="@+id/switch_status" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:layout_centerVertical="true" tools:ignore="UseSwitchCompatOrMaterialXml" />
                </RelativeLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

                <!-- Mục lục label -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingVertical="20dp">
                    <TextView android:id="@+id/tv_chapters_count_label" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mục lục" android:textColor="@color/black" android:textStyle="bold" android:textSize="15sp"/>
                    <ImageView android:id="@+id/btn_settings" android:layout_width="24dp" android:layout_height="24dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:src="@drawable/ic_settings" app:tint="@color/black" />
                </RelativeLayout>

                <!-- Container cho danh sách chương -->
                <LinearLayout
                    android:id="@+id/container_chapters_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <View android:layout_width="match_parent" android:layout_height="100dp" />
            </LinearLayout>
        </ScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:background="@color/white"
            android:elevation="10dp"
            android:orientation="horizontal">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_add_chapter"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="48dp"
                android:layout_marginEnd="12dp"
                android:text="+ THÊM CHƯƠNG"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="12sp"
                app:backgroundTint="#D9A441"
                app:cornerRadius="24dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_delete_book"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="48dp"
                android:text="🗑 XÓA TRUYỆN"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="12sp"
                app:backgroundTint="#D9A441"
                app:cornerRadius="24dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- POPUPS -->
    <LinearLayout android:id="@+id/popup_edit_title" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/white" android:orientation="vertical" android:visibility="gone">
        <RelativeLayout android:layout_width="match_parent" android:layout_height="56dp" android:paddingHorizontal="16dp" android:layout_marginTop="27dp"><ImageView android:id="@+id/btn_back_title" android:layout_width="24dp" android:layout_height="24dp" android:layout_centerVertical="true" android:src="@drawable/ic_back_arrow" app:tint="@color/black" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerInParent="true" android:text="Tiêu đề" android:textColor="@color/black" android:textSize="18sp" android:textStyle="bold" /></RelativeLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" /><EditText android:id="@+id/et_edit_title" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_margin="16dp" android:background="@null" android:textColor="@color/black" android:textSize="16sp" /></LinearLayout>

    <LinearLayout android:id="@+id/popup_edit_desc" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/white" android:orientation="vertical" android:visibility="gone">
        <RelativeLayout android:layout_width="match_parent" android:layout_height="56dp" android:paddingHorizontal="16dp" android:layout_marginTop="27dp"><ImageView android:id="@+id/btn_back_desc" android:layout_width="24dp" android:layout_height="24dp" android:layout_centerVertical="true" android:src="@drawable/ic_back_arrow" app:tint="@color/black" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerInParent="true" android:text="Mô tả" android:textColor="@color/black" android:textSize="18sp" android:textStyle="bold" /></RelativeLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" /><EditText android:id="@+id/et_edit_desc" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_margin="16dp" android:background="@null" android:gravity="top" android:textColor="@color/black" android:textSize="15sp" android:inputType="textMultiLine" /></LinearLayout>

    <LinearLayout android:id="@+id/popup_choose_category" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/white" android:orientation="vertical" android:visibility="gone">
        <RelativeLayout android:layout_width="match_parent" android:layout_height="56dp" android:paddingHorizontal="16dp" android:layout_marginTop="27dp"><ImageView android:id="@+id/btn_back_category" android:layout_width="24dp" android:layout_height="24dp" android:layout_centerVertical="true" android:src="@drawable/ic_back_arrow" app:tint="@color/black" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerInParent="true" android:text="Chọn thể loại" android:textColor="@color/black" android:textSize="18sp" android:textStyle="bold" /></RelativeLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" /><ScrollView android:layout_width="match_parent" android:layout_height="match_parent"><LinearLayout android:id="@+id/container_categories" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" /></ScrollView></LinearLayout>
    <LinearLayout android:id="@+id/popup_manage_chapters" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/white" android:orientation="vertical" android:visibility="gone">
        <RelativeLayout android:layout_width="match_parent" android:layout_height="64dp" android:paddingHorizontal="16dp" android:layout_marginTop="27dp">
            <ImageView android:id="@+id/btn_close_manage_chapters" android:layout_width="24dp" android:layout_height="24dp" android:layout_centerVertical="true" android:src="@android:drawable/ic_menu_close_clear_cancel" app:tint="@color/black" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerInParent="true" android:text="Chọn chương truyện" android:textColor="@color/black" android:textSize="18sp" android:textStyle="bold" />
        </RelativeLayout>
        
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />
        
        <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
            <LinearLayout android:id="@+id/container_manage_chapters_list" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingHorizontal="16dp" android:paddingVertical="8dp" />
        </ScrollView>
        
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />
        
        <LinearLayout android:layout_width="match_parent" android:layout_height="72dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="24dp" android:background="@color/white" android:elevation="8dp">
            <TextView android:id="@+id/btn_delete_selected_chapters" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="XÓA" android:textColor="#888888" android:textStyle="bold" android:textSize="14sp" android:clickable="true" android:focusable="true"/>
            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
            <TextView android:id="@+id/btn_status_selected_chapters" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ĐĂNG" android:textColor="#888888" android:textStyle="bold" android:textSize="14sp" android:clickable="true" android:focusable="true"/>
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
