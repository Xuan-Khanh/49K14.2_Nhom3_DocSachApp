<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/white">

    <!-- Nút quay lại -->
    <ImageView
        android:id="@+id/btn_back"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_back_arrow"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="32dp"
        android:contentDescription="Back" />

    <!-- Tiêu đề chính -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Quên mật khẩu"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:fontFamily="@font/inter_bold"
        android:layout_marginBottom="12dp"/>

    <!-- Đoạn mô tả -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nhập mã OTP của bạn mã để đặt lại mật khẩu"
        android:textSize="15sp"
        android:textColor="#999999"
        android:lineSpacingExtra="4dp"
        android:fontFamily="@font/inter_regular"
        android:layout_marginBottom="32dp"/>

    <!-- Nhãn trường nhập -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mã OTP"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:textSize="15sp"
        android:fontFamily="@font/inter_bold"
        android:layout_marginBottom="8dp"/>

    <!-- Ô nhập OTP -->
    <EditText
        android:id="@+id/et_otp"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/bg_edittext_rounded"
        android:hint="Nhập mã OTP"
        android:textColorHint="#CCCCCC"
        android:paddingHorizontal="20dp"
        android:inputType="number"
        android:textSize="14sp"
        android:fontFamily="@font/inter_regular"
        android:layout_marginBottom="12dp"/>

    <!-- Bộ đếm thời gian và Nút Refresh -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginStart="8dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/tv_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="01:00"
            android:textColor="#999999"
            android:textSize="14sp"
            android:fontFamily="@font/inter_regular" />

        <ImageView
            android:id="@+id/iv_refresh"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_refresh"
            app:tint="#999999" />
    </LinearLayout>

    <!-- Thông báo lỗi (mặc định ẩn) -->
    <TextView
        android:id="@+id/tv_error"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nhập sai OTP. Vui lòng nhập lại."
        android:textColor="@color/error"
        android:visibility="gone"
        android:layout_marginBottom="16dp"/>

    <!-- View đệm để đẩy nút xuống dưới cùng -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Nút Gửi (giữ ID btn_verify) -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_verify"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Gửi"
        android:textAllCaps="false"
        android:background="@drawable/bg_button_black"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:fontFamily="@font/inter_bold" />

</LinearLayout>