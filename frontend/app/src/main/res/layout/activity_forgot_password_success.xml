<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/white">

    <!-- Nút quay lại -->
    <ImageView
        android:id="@+id/btn_back"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_back_arrow"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="32dp"
        android:contentDescription="Back" />

    <!-- View đệm để đẩy nội dung xuống vị trí cân đối -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.5" />

    <!-- Hình minh họa thành công (thanhcong.png) -->
    <ImageView
        android:layout_width="280dp"
        android:layout_height="200dp"
        android:layout_gravity="center_horizontal"
        android:src="@drawable/thanhcong"
        android:scaleType="fitCenter"
        android:layout_marginBottom="40dp" />

    <!-- Tiêu đề -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cập nhật thành công"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:gravity="center"
        android:fontFamily="@font/inter_bold"
        android:layout_marginBottom="12dp"/>

    <!-- Mô tả chi tiết -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mật khẩu của bạn đã thay đổi thành công.\nVui lòng sử dụng mật khẩu mới cho lần\nđăng nhập tiếp theo."
        android:textSize="15sp"
        android:textColor="#999999"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:fontFamily="@font/inter_regular"
        android:layout_marginBottom="32dp"/>

    <!-- View đệm để đẩy nút xuống dưới cùng -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Nút Quay lại (giữ nguyên ID) -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_back_to_login"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Quay lại Màn hình Đăng nhập"
        android:textAllCaps="false"
        android:background="@drawable/bg_button_black"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:fontFamily="@font/inter_bold" />

</LinearLayout>