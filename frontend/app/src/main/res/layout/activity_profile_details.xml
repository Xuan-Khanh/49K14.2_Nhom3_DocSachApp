<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp"
        android:layout_above="@+id/ll_buttons">

        <!-- Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp">
            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_back_arrow"
                app:tint="@color/black" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Chi tiết tài khoản"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:fontFamily="@font/inter_bold"/>
        </RelativeLayout>

        <!-- Avatar -->
        <com.makeramen.roundedimageview.RoundedImageView
            android:id="@+id/iv_avatar"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="40dp"
            android:src="@android:drawable/ic_menu_gallery"
            android:scaleType="centerCrop"
            app:riv_oval="true"
            android:background="#F0F0F0"/>

        <!-- Section Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="THÔNG TIN CÁ NHÂN"
            android:textColor="#9BA4B5"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"
            android:fontFamily="@font/inter_bold"/>

        <!-- Form Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_profile_card"
            android:padding="16dp">

            <!-- Username -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="TÊN ĐĂNG NHẬP"
                android:textColor="#CCCCCC"
                android:textSize="10sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tv_username"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="MeoMeo"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:paddingVertical="8dp"
                android:fontFamily="@font/inter_regular"/>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F5F5F5" android:layout_marginBottom="12dp"/>

            <!-- Email -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="EMAIL"
                android:textColor="#CCCCCC"
                android:textSize="10sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tv_email"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="user_example@gmail.com"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:paddingVertical="8dp"
                android:fontFamily="@font/inter_regular"/>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F5F5F5" android:layout_marginBottom="12dp"/>

            <!-- Password -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="MẬT KHẨU"
                android:textColor="#CCCCCC"
                android:textSize="10sp"
                android:textStyle="bold" />
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:id="@+id/tv_password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="••••••"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    android:paddingVertical="8dp"
                    android:fontFamily="@font/inter_regular"/>
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_visibility_off"
                    app:tint="#CCCCCC"/>
            </RelativeLayout>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F5F5F5" android:layout_marginBottom="12dp"/>

            <!-- Birthday -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="NGÀY SINH"
                android:textColor="#CCCCCC"
                android:textSize="10sp"
                android:textStyle="bold" />
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:id="@+id/tv_birthday"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="01/01/1995"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    android:paddingVertical="8dp"
                    android:fontFamily="@font/inter_regular"/>
                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@android:drawable/ic_menu_my_calendar"
                    app:tint="@color/black"/>
            </RelativeLayout>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F5F5F5" android:layout_marginBottom="12dp"/>

            <!-- Bio -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="MÔ TẢ"
                android:textColor="#CCCCCC"
                android:textSize="10sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tv_bio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Yêu thích viết lách và khám phá những chân trời mới."
                android:textColor="@color/black"
                android:textSize="14sp"
                android:paddingVertical="8dp"
                android:fontFamily="@font/inter_regular"/>

        </LinearLayout>
    </LinearLayout>

    <!-- Bottom Buttons -->
    <LinearLayout
        android:id="@+id/ll_buttons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_alignParentBottom="true"
        android:padding="24dp">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_edit"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Chỉnh sửa thông tin"
            android:textAllCaps="false"
            android:background="@drawable/bg_button_black"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"
            android:fontFamily="@font/inter_bold"/>
        <!-- Nút Đăng xuất ở dưới cùng -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_logout"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_alignParentBottom="true"
            android:text="Đăng xuất"
            android:textAllCaps="false"
            android:background="@drawable/bg_button_black"
            android:backgroundTint="#D9A441"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

</RelativeLayout>
