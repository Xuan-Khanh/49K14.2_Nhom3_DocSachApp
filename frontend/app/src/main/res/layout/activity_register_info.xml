<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/white"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Back Button -->
        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_back_arrow"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="32dp"
            android:contentDescription="Back" />

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Giới thiệu về bản thân bạn"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:fontFamily="@font/inter_bold"
            android:layout_marginBottom="32dp"/>

        <!-- Email Label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Email"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:textSize="15sp"
            android:fontFamily="@font/inter_bold"
            android:layout_marginBottom="8dp"/>

        <!-- Email Field -->
        <EditText
            android:id="@+id/et_email"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_edittext_rounded"
            android:hint="Email"
            android:textColorHint="#CCCCCC"
            android:paddingHorizontal="20dp"
            android:inputType="textEmailAddress"
            android:textSize="14sp"
            android:fontFamily="@font/inter_regular"
            android:layout_marginBottom="24dp"/>

        <!-- Username Label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tên đăng nhập"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:textSize="15sp"
            android:fontFamily="@font/inter_bold"
            android:layout_marginBottom="8dp"/>

        <!-- Username Field -->
        <EditText
            android:id="@+id/et_username"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_edittext_rounded"
            android:hint="Tên đăng nhập"
            android:textColorHint="#CCCCCC"
            android:paddingHorizontal="20dp"
            android:textSize="14sp"
            android:fontFamily="@font/inter_regular"
            android:layout_marginBottom="8dp"/>

        <!-- Username Note -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bạn không cần phải dùng tên thật. Bạn có thể chọn một tên gọi khác để bảo vệ sự riêng tư cá nhân."
            android:textSize="12sp"
            android:textColor="#999999"
            android:fontFamily="@font/inter_regular"
            android:layout_marginBottom="24dp"/>

        <!-- DOB Label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ngày sinh của bạn là?"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:textSize="15sp"
            android:fontFamily="@font/inter_bold"
            android:layout_marginBottom="8dp"/>

        <!-- DOB Fields Group -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <EditText
                android:id="@+id/et_dob_mm"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:background="@drawable/bg_edittext_rounded"
                android:hint="MM"
                android:gravity="center"
                android:textColorHint="#CCCCCC"
                android:inputType="number"
                android:textSize="14sp"
                android:fontFamily="@font/inter_regular" />

            <EditText
                android:id="@+id/et_dob_dd"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="12dp"
                android:background="@drawable/bg_edittext_rounded"
                android:hint="DD"
                android:gravity="center"
                android:textColorHint="#CCCCCC"
                android:inputType="number"
                android:textSize="14sp"
                android:fontFamily="@font/inter_regular" />

            <EditText
                android:id="@+id/et_dob_yyyy"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1.5"
                android:background="@drawable/bg_edittext_rounded"
                android:hint="NNNN"
                android:gravity="center"
                android:textColorHint="#CCCCCC"
                android:inputType="number"
                android:textSize="14sp"
                android:fontFamily="@font/inter_regular" />

            <!-- Hidden field for compatibility with Java ID et_dob if needed -->
            <EditText
                android:id="@+id/et_dob"
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- DOB Note -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ngày sinh của bạn chỉ hiển thị với bạn và đội ngũ hỗ trợ của TW."
            android:textSize="12sp"
            android:textColor="#999999"
            android:fontFamily="@font/inter_regular"
            android:layout_marginBottom="16dp"/>

        <!-- Error Message -->
        <TextView
            android:id="@+id/tv_error"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Email hoặc tên đăng nhập của bạn bị trùng"
            android:textColor="@color/error"
            android:visibility="gone"
            android:layout_marginBottom="16dp"
            android:fontFamily="@font/inter_regular"/>

        <!-- Spacer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Continue Button -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_continue"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:text="Tiếp tục"
            android:textAllCaps="false"
            android:background="@drawable/bg_button_black"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="@font/inter_bold" />

    </LinearLayout>
</ScrollView>
