<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top Bar -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingHorizontal="16dp"
            android:layout_marginTop="27dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Menu"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/black" />
        </RelativeLayout>

        <!-- User Info -->
        <RelativeLayout
            android:id="@+id/rl_user_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <com.makeramen.roundedimageview.RoundedImageView
                android:id="@+id/iv_avatar"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@android:drawable/ic_menu_gallery"
                android:scaleType="centerCrop"
                app:riv_oval="true"
                android:background="#F0F0F0" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@+id/iv_avatar"
                android:layout_centerVertical="true"
                android:layout_marginStart="16dp"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tv_username"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Username"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/black" />
                <TextView
                    android:id="@+id/tv_bio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chưa có mô tả"
                    android:textSize="14sp"
                    android:textColor="#666666" />
            </LinearLayout>

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@android:drawable/arrow_up_float"
                android:rotation="90"
                app:tint="#CCCCCC" />
        </RelativeLayout>

        <!-- Stats -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="24dp"
            android:gravity="center">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/tv_story_count"
                    android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="16sp" android:textStyle="bold" android:textColor="@color/black"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tác phẩm" android:textSize="13sp" android:textColor="@color/black"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/tv_followers"
                    android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="16sp" android:textStyle="bold" android:textColor="@color/black"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Người theo dõi" android:textSize="13sp" android:textColor="@color/black"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/tv_following"
                    android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="16sp" android:textStyle="bold" android:textColor="@color/black"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Đang theo dõi" android:textSize="13sp" android:textColor="@color/black"/>
            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

        <!-- Menu List -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Section: THÔNG BÁO -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="20dp"
                    android:paddingBottom="8dp"
                    android:text="THÔNG BÁO"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#999999" />

                <RelativeLayout
                    android:id="@+id/rl_notifications"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:paddingHorizontal="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">
                    <ImageView
                        android:id="@+id/iv_icon_notif"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_centerVertical="true"
                        android:src="@android:drawable/ic_popup_reminder"
                        app:tint="#D9A441" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@+id/iv_icon_notif"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="16dp"
                        android:text="Thông báo của tôi"
                        android:textSize="15sp"
                        android:textColor="@color/black" />
                </RelativeLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginHorizontal="16dp"/>

                <!-- Section: THƯ VIỆN -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="20dp"
                    android:paddingBottom="8dp"
                    android:text="THƯ VIỆN"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#999999" />

                <RelativeLayout
                    android:id="@+id/rl_library"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:paddingHorizontal="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">
                    <ImageView
                        android:id="@+id/iv_icon_library"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_centerVertical="true"
                        android:src="@android:drawable/ic_menu_my_calendar"
                        app:tint="#D9A441" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@+id/iv_icon_library"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="16dp"
                        android:text="Thư viện của tôi"
                        android:textSize="15sp"
                        android:textColor="@color/black" />
                </RelativeLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginHorizontal="16dp"/>

                <!-- Section: LỊCH SỬ TÀI KHOẢN -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="20dp"
                    android:paddingBottom="8dp"
                    android:text="LỊCH SỬ TÀI KHOẢN"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#999999" />

                <RelativeLayout
                    android:id="@+id/rl_comments"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:paddingHorizontal="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">
                    <ImageView
                        android:id="@+id/iv_icon_comments"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_centerVertical="true"
                        android:src="@android:drawable/btn_star_big_on"
                        app:tint="#D9A441" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@+id/iv_icon_comments"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="16dp"
                        android:text="Bình luận của tôi"
                        android:textSize="15sp"
                        android:textColor="@color/black" />
                </RelativeLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginHorizontal="16dp"/>

                <!-- Nút Đăng xuất -->
                <RelativeLayout
                    android:id="@+id/rl_logout"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:paddingHorizontal="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">
                    <ImageView
                        android:id="@+id/iv_icon_logout"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_centerVertical="true"
                        android:src="@android:drawable/ic_menu_close_clear_cancel"
                        app:tint="#FF4444" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@+id/iv_icon_logout"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="16dp"
                        android:text="Đăng xuất"
                        android:textSize="15sp"
                        android:textColor="#FF4444"
                        android:textStyle="bold" />
                </RelativeLayout>

                <View android:layout_width="match_parent" android:layout_height="24dp" />

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

</RelativeLayout>